	keywords = {Human behaviour, Intelligence},
	pages = {39589},
	file = {Full Text PDF:/Users/chrissoria/Zotero/storage/NALXIP9G/Kaplan et al. - 2016 - Neural correlates of maintaining one’s political b.pdf:application/pdf},
}

